{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/rally", "destination": "/rally/index.html" }
  ],
  "redirects": [
    { "source": "/baldwin",     "destination": "/take-action/baldwins", "permanent": false },
    { "source": "/baldwins",    "destination": "/take-action/baldwins", "permanent": false },
    { "source": "/defend",      "destination": "/take-action/baldwins#donate", "permanent": false },
    { "source": "/about-us",    "destination": "/the-fight",            "permanent": false },
    { "source": "/about-us.html","destination": "/the-fight",           "permanent": false },
    { "source": "/petition",    "destination": "/take-action/hold-the-gate#sign", "permanent": false },
    { "source": "/holdthegate", "destination": "/petition",                       "permanent": false }
  ],
  "headers": [
    {
      "source": "/content/site.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/api/youtube",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=600, stale-while-revalidate=3600" }
      ]
    }
  ]
}
